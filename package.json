{
  "name": "smartcovering-erp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "deploy:check": "npm run build && node server/services/erpValidationCheck.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "node server/index.js",
    "db:schema": "psql \"$DATABASE_URL\" -f server/db/schema.sql",
    "db:create-user": "node server/db/createUser.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.17.1",
    "pg": "^8.13.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
