NODE_ENV=production
PORT=4000

# Neon Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
PGSSLMODE=require

# Generate long random values for production.
JWT_SECRET=replace-with-a-long-random-secret
WEBHOOK_SHARED_SECRET=replace-with-a-long-random-secret
APP_STATE_SHARED_SECRET=

# Comma-separated frontend origins. For full-stack Render deploy, use the Render URL.
CLIENT_ORIGIN=https://your-frontend-domain.vercel.app,https://your-render-service.onrender.com

# Only needed when a separate frontend/static HTML must call a different API domain.
# Set these as window.SMARTCOVERING_API_URL / window.SMARTCOVERING_STATE_SECRET in that frontend shell.
